#!/bin/bash

MSG_FILE="$1"
TMP_FILE="${MSG_FILE}.tmp"

# Remove all variants of Co-authored-by metadata lines
sed -E '/^Co[- ]?[Aa]uthored[- ]?[Bb]y:/d' "$MSG_FILE" > "$TMP_FILE"

# Only replace if something changed
if ! cmp -s "$MSG_FILE" "$TMP_FILE"; then
    mv "$TMP_FILE" "$MSG_FILE"
fi
rm -f "$TMP_FILE"
